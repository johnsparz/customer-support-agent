# ==========================================================
# AI Customer Support Agent
# Environment Configuration
# Copy this file to ".env" and replace the placeholder values.
# Never commit your real .env file to source control.
# ==========================================================

# -------------------------
# LLM Configuration
# -------------------------
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# -------------------------
# Application Settings
# -------------------------
APP_NAME=AI Customer Support Agent
APP_ENV=development
APP_DEBUG=True
LOG_LEVEL=INFO

# -------------------------
# Paths
# -------------------------
DATA_DIR=data
LOG_DIR=logs
VECTORSTORE_DIR=data/vectorstore
COMPANY_HANDBOOK=data/Company_Handbook.pdf

# -------------------------
# RAG Configuration
# -------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=4

# -------------------------
# Streamlit
# -------------------------
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_SERVER_PORT=8501

# -------------------------
# Optional Web Search Settings
# -------------------------
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT=20

# -------------------------
# Conversation
# -------------------------
MAX_HISTORY_MESSAGES=20

# -------------------------
# Logging
# -------------------------
LOG_FILE=customer_support_agent.log